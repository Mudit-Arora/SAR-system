# =============================================================================
# .env.example
# -----------------------------------------------------------------------------
# Documents the environment variables the data-gathering / build steps expect.
# Copy to .env and fill in real values. .env is git-ignored; never commit it.
# =============================================================================

# OpenTopography API key — for downloading USGS 3DEP DEM tiles.
# Get one free at: https://portal.opentopography.org/  (Account → Request API Key)
OPENTOPOGRAPHY_API_KEY=

# Kaggle credentials — only needed if you prefer .env over ~/.kaggle/kaggle.json
# for the SARD dataset download. Get them at: https://www.kaggle.com/  (Account →
# Create New API Token, which downloads a kaggle.json containing these two fields).
# KAGGLE_USERNAME=
# KAGGLE_KEY=

# --- Build-time keys (Saturday) ----------------------------------------------

# Anthropic (Claude) — composes the subject-broadcast message + parses operator intent.
# Get one at: https://console.anthropic.com/  (API Keys)
ANTHROPIC_API_KEY=

# Deepgram — speech-to-text (operator interface) + text-to-speech (subject broadcast).
# Get one at: https://console.deepgram.com/  (API Keys)
DEEPGRAM_API_KEY=

# Sentry (optional) — error monitoring; near-free reliability story for a safety-critical demo.
# Read by integration/observability.py (the server + loop CLI). Leave blank to keep monitoring
# OFF (the SDK becomes a no-op and the demo/tests are unchanged); fill in to turn it on.
# Get a DSN at: https://sentry.io/  (Project → Settings → Client Keys (DSN))
SENTRY_DSN=
# Optional tuning (defaults shown): which deployment tag events get, and the perf-trace sample rate.
# SENTRY_ENVIRONMENT=demo
# SENTRY_TRACES_SAMPLE_RATE=0.2
